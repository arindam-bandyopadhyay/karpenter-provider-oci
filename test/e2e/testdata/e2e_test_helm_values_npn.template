replicaCount: 1
image:
  registry: VAR_IMAGE_REGISTRY
  repositoryName: VAR_IMAGE_REPOSITORY_NAME
  tag: VAR_IMAGE_TAG
settings:
  # -- Cluster compartment OCID
  clusterCompartmentId: "VAR_COMPARTMENT_ID"
  # -- Cluster's VCN compartment OCID
  vcnCompartmentId: "VAR_COMPARTMENT_ID"
  featureGates:
    nodeOverlay: true
    staticCapacity: true
  # -- set this to true for a cluster run with OciIpNativeCni
  ociVcnIpNative: true
  # -- by default only IPv4, add IPv6 in needed
  ipFamilies: [IPv4]
  apiserverEndpoint: VAR_NPN_KUBEAPI_ENDPOINT_IP
  flexibleShapeConfigs:
    - ocpus: 2
      memoryInGbs: 16
      baselineOcpuUtilization: BASELINE_1_2
    - ocpus: 4
      memoryInGbs: 32
#  repairPolicies:
#    - conditionType: Ready
#      conditionStatus: "False"
#      tolerationDuration: 30s
